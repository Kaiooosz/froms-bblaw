generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String       @id @default(cuid())
  name              String?
  email             String?      @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  fullName          String?
  document          String?
  birthDate         String?
  role              String       @default("USER")
  origemLead        String?      @default("DIRETO")
  phone             String?
  resetToken        String?      @unique
  resetTokenExpires DateTime?
  accounts          Account[]
  sessions          Session[]
  leads             Lead[]
  submissions       Submission[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Submission {
  id         String   @id @default(cuid())
  userId     String
  funnelType String
  status     String   @default("PENDING")
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  priority   String?  @default("A DEFINIR")
  score      Int?
  tags       String[]
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("submissions")
}

model Lead {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  relacao_empresa       String
  whatsapp              String
  participacao          Int?
  socio_responsavel     String?
  empresa_opcao1        String
  empresa_opcao2        String?
  empresa_opcao3        String?
  jurisdicao            String
  jurisdicao_outra      String?
  imoveis_brasil        String
  uso_empresa           String[]
  uso_empresa_outro     String?
  atividade_empresa     String?
  conta_bancaria        String
  ativos_texto          String?
  diretor_tipo          String?
  herdeiros             String?
  origem_fundos         String[]
  origem_fundos_outro   String?
  nome_completo_pessoal String
  data_nascimento       String
  genero                String?
  estado_civil          String?
  endereco              String?
  passaporte            String?
  cidade_nascimento     String?
  telefone              String?
  email                 String
  residencia_fiscal     String?
  cpf_nit               String?
  ocupacao              String
  cnpj                  String?
  empresa_trabalha      String?
  funcao                String?
  pep                   String
  residencia_eua        String
  declaracao_aceite     Boolean
  documento_identidade  String?
  documento_residencia  String?
  userId                String?
  user                  User?    @relation(fields: [userId], references: [id])
  priority              String?  @default("A DEFINIR")

  @@map("leads")
}
